{
  "$schema": "https://turborepo.org/schema.json",
  "tasks": {
    "dev": {
      "cache": false,
      "persistent": true
    },
    "dev-ele": {
      "dependsOn": [
        "^dev"
      ],
      "cache": false
    },
    "build": {
      "outputs": [
        "build/**"
      ]
    },
    "build-ele": {
      "outputs": [
        "dist-ele/**"
      ],
      "dependsOn": [
        "^build"
      ]
    },
    "build-ele:mac": {
      "outputs": [
        "dist-ele/**"
      ],
      "dependsOn": [
        "^build"
      ]
    },
    "build-ele:win": {
      "outputs": [
        "dist-ele/**"
      ],
      "dependsOn": [
        "^build"
      ]
    },
    "build-ele:linux": {
      "outputs": [
        "dist-ele/**"
      ],
      "dependsOn": [
        "^build"
      ]
    },
    "build-ele:linux-arm64": {
      "outputs": [
        "dist-ele/**"
      ],
      "dependsOn": [
        "^build"
      ]
    },
    "lint": {
      "outputs": []
    },
    "test": {
      "outputs": []
    },
    "clean": {
      "dependsOn": [
        "^clean"
      ]
    },
    "storybook": {
      "dependsOn": [
        "^build"
      ],
      "cache": false,
      "persistent": true
    },
    "build-storybook": {
      "dependsOn": [
        "^build"
      ],
      "outputs": [
        "storybook-static/**"
      ]
    }
  },
  "ui": "stream"
}
