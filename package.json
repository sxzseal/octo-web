{
  "name": "octo-web",
  "private": true,
  "version": "1.5.0",
  "scripts": {
    "dev": "turbo run dev --parallel",
    "dev-ele": "turbo run dev-ele --parallel",
    "build": "turbo run build",
    "build-ele": "turbo run build && turbo run build-ele",
    "build-ele:mac": "turbo run build && turbo run build-ele:mac",
    "build-ele:win": "turbo run build && turbo run build-ele:win",
    "build-ele:linux": "turbo run build && turbo run build-ele:linux",
    "build-ele:linux-arm64": "turbo run build && turbo run build-ele:linux-arm64",
    "bootstrap": "yarn install",
    "clean": "turbo run clean && rimraf node_modules .turbo",
    "lint": "turbo run lint",
  "lint:css": "stylelint '**/*.css' --config stylelint.config.mjs --allow-empty-input",
  "lint:css:ci": "stylelint --config stylelint.ci.config.mjs --allow-empty-input",
    "format": "prettier --write \"**/*.{ts,tsx,md}\""
  },
  "resolutions": {
    "react-error-overlay": "6.0.9"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "eslint": "^7.32.0",
    "eslint-config-custom": "*",
    "prettier": "^2.5.1",
    "rimraf": "^5.0.5",
    "stylelint": "^17.6.0",
    "stylelint-config-standard": "^40.0.0",
    "turbo": "2.2.1",
    "vitest": "^4.1.1"
  },
  "engines": {
    "node": ">=18.0.0",
    "yarn": ">=1.22.19"
  },
  "dependencies": {
    "@babel/plugin-proposal-private-property-in-object": "^7.21.11",
    "lucide-react": "^0.577.0",
    "pinyin-pro": "^3.28.0",
    "zxcvbn": "^4.4.2"
  },
  "packageManager": "pnpm@10.32.0",
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
