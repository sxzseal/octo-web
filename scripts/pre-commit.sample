#!/usr/bin/env bash

# pre-commit hook: 架构 lint（只检查 staged 文件）

# 自动探测 node（支持 nvm / fnm / volta / 系统 node）
if [ -s "$HOME/.nvm/nvm.sh" ]; then
  source "$HOME/.nvm/nvm.sh" --no-use
  nvm use default --silent 2>/dev/null
elif [ -d "$HOME/.fnm" ]; then
  eval "$(fnm env 2>/dev/null)" 2>/dev/null
elif [ -d "$HOME/.volta" ]; then
  export PATH="$HOME/.volta/bin:$PATH"
fi

if ! command -v node &>/dev/null; then
  echo "⚠️  node 未找到，跳过 architecture lint"
  exit 0
fi

# 找到仓库根目录（兼容 worktree）
REPO_ROOT="$(git rev-parse --show-toplevel)"

# 查找 lint 脚本（worktree 中可能没有 scripts/）
LINT_SCRIPT="$REPO_ROOT/scripts/lint-architecture.mjs"
if [ ! -f "$LINT_SCRIPT" ]; then
  # 尝试从 git 主工作目录找
  MAIN_WORKTREE="$(git worktree list --porcelain | head -1 | sed 's/^worktree //')"
  LINT_SCRIPT="$MAIN_WORKTREE/scripts/lint-architecture.mjs"
  if [ ! -f "$LINT_SCRIPT" ]; then
    exit 0
  fi
fi

echo "🏗  Running architecture lint..."
node "$LINT_SCRIPT" --staged

EXIT_CODE=$?
if [ $EXIT_CODE -ne 0 ]; then
  echo ""
  echo "❌ Architecture lint 失败，commit 被阻止。"
  echo "   修复上述问题后重新 commit。"
  echo ""
  exit 1
fi
